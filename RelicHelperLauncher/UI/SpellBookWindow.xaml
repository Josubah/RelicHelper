<Window x:Class="RelicHelper.SpellBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RelicHelper"
        mc:Ignorable="d"
        Title="Spell Book &amp; Hotkeys" Height="550" Width="800" Background="#1e1e1e" Foreground="#bfbfbf" WindowStartupLocation="CenterOwner" Topmost="True" WindowState="Normal">
    <Window.Resources>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#333333" />
            <Setter Property="Foreground" Value="Gold" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="BorderBrush" Value="#444444" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#252525" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="280" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" /> <!-- Title -->
                <RowDefinition Height="*" />    <!-- DataGrid -->
                <RowDefinition Height="Auto" /> <!-- Add Button -->
                <RowDefinition Height="Auto" /> <!-- Save Button -->
            </Grid.RowDefinitions>

            <Label Grid.Row="0" Content="Your Spell Hotkeys (Auto-Timer)" Foreground="Gold" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <DataGrid Grid.Row="1" x:Name="SpellDataGrid" AutoGenerateColumns="False" Background="#252525" RowBackground="#252525" Foreground="White" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#333333" CanUserAddRows="False" BorderBrush="#444444" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridComboBoxColumn x:Name="HotkeyColumn" Header="Hotkey" SelectedItemBinding="{Binding Hotkey}" Width="120" />
                    <DataGridTextColumn Header="Duration (s)" Binding="{Binding DurationSeconds}" Width="100" />
                    <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsEnabled}" Width="60" />
                    <DataGridTemplateColumn Header="Action" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Remove" Click="DeleteSpell_Click" Background="#aa0000" Foreground="White" FontSize="10" Padding="5,2,5,2" BorderThickness="0" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="2" x:Name="AddSpellButton" Content="+ ADD NEW SPELL LINE" Margin="0,10,0,0" Height="30" Background="#333333" Foreground="Gold" FontWeight="Bold" Click="AddSpellButton_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#555555" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Grid.Row="3" x:Name="SaveButton" Content="SAVE SETTINGS (CLICK HERE TO APPLY)" Margin="0,15,0,0" Height="45" Background="#004d00" Foreground="White" FontWeight="Bold" Click="SaveButton_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="Gold" BorderThickness="1" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <StackPanel Grid.Column="1" Margin="20,0,0,0">
            <Label Content="Spell Reference Book" Foreground="Gold" FontSize="16" FontWeight="Bold" Margin="0,0,0,5"/>
            <Border BorderBrush="#444444" BorderThickness="1" Padding="15" Background="#252525" CornerRadius="4">
                <TextBlock TextWrapping="Wrap" Foreground="#cccccc" LineHeight="20">
                    <Bold FontSize="13" Foreground="White">How it works:</Bold><LineBreak/>
                    1. Click <Bold Foreground="Gold">'+ ADD NEW SPELL LINE'</Bold> to start.<LineBreak/>
                    2. Select your in-game <Italic>Hotkey</Italic> (ex: F1, F2).<LineBreak/>
                    3. Set the cooldown duration in seconds.<LineBreak/>
                    4. Click <Bold Foreground="Green">'SAVE SETTINGS'</Bold> to apply.<LineBreak/>
                    <LineBreak/>
                    <Bold Foreground="Gold">Quick Templates:</Bold><LineBreak/>
                    • Haste: <Span Foreground="Cyan">30.0s</Span><LineBreak/>
                    • Strong Haste: <Span Foreground="Cyan">20.0s</Span><LineBreak/>
                    • Healing Flow: <Span Foreground="Cyan">18.0s</Span><LineBreak/>
                    • Invisible: <Span Foreground="Cyan">200.0s</Span><LineBreak/>
                    • Magic Shield: <Span Foreground="Cyan">60.0s</Span><LineBreak/>
                    <LineBreak/>
                    <Italic FontSize="10" Foreground="#888888">Note: The timer starts when you press the key while the game is focused.</Italic>
                </TextBlock>
            </Border>
            <Button x:Name="AddDefaultsButton" Content="LOAD DEFAULT TEMPLATES" Margin="0,20,0,0" Height="30" Click="AddDefaultsButton_Click" Background="#333333" Foreground="White" BorderBrush="#555555"/>
        </StackPanel>
    </Grid>
</Window>
