<Window x:Name="OverlayWindow" x:Class="RelicHelper.GameClientOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:s="clr-namespace:System;assembly=mscorlib"
        xmlns:local="clr-namespace:RelicHelper"
        mc:Ignorable="d"
        Title="GameClientOverlayWindow" Background="Transparent" WindowStyle="None" BorderBrush="Black" AllowsTransparency="True" Topmost="True" MaxWidth="253" MinWidth="150" MaxHeight="850" MinHeight="850" ResizeMode="NoResize" ShowInTaskbar="False" GotFocus="OverlayWindow_GotFocus" Width="255" Height="850">
    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#bfbfbf"/>
            <Setter Property="FontFamily" Value="Verdana"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Name="border" BorderThickness="1" BorderBrush="DarkGray" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="AntiqueWhite"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="Gray"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#bfbfbf"/>
            <Setter Property="Background" Value="#7F000000"/>
            <Setter Property="FontFamily" Value="Verdana"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="8,3,8,3"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Verdana"/>
            <Setter Property="Background" Value="#7F000000"/>
            <Setter Property="Foreground" Value="#bfbfbf"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="Red"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="5"/>
        </Style>
    </Window.Resources>
    <Viewbox VerticalAlignment="Top" SnapsToDevicePixels="True">
        <StackPanel Width="253" Background="Transparent" VerticalAlignment="Top">
            <!-- Stats Section -->
            <StackPanel Margin="5,0,5,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Experience / Stats" FontWeight="Bold" Foreground="AntiqueWhite"/>
                    <Button Content="[-]" Grid.Column="1" Width="25" Height="18" Padding="0" FontSize="10" Click="ToggleSection_Click" Tag="StatsContent"/>
                </Grid>
                <StackPanel x:Name="StatsContent">
                    <Grid>
                        <Label Content="Ping Server:" />
                        <Label x:Name="PingLabel" Content="-" Margin="100,0,0,0"/>
                    </Grid>
                    <Grid>
                        <Label Content="Ping Google:" />
                        <Label x:Name="PingLabel2" Content="-" Margin="100,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,5,0,0">
                        <Label Content="Experience:" />
                        <Label x:Name="ExperienceLabel" Content="-" Margin="100,0,0,0"/>
                    </Grid>
                    <Grid>
                        <Label Content="Level:" />
                        <Label x:Name="LevelLabel" Content="-" Margin="50,0,0,0"/>
                    </Grid>
                    <ProgressBar x:Name="LevelProgressBar" Height="5" Margin="0,5,0,5" Width="238" BorderBrush="Black" Background="{x:Null}"/>
                    <Grid>
                        <Label Content="Exp. left:" />
                        <Label x:Name="ExperienceRemainingLabel" Content="-" Margin="80,0,0,0"/>
                    </Grid>
                    <Grid>
                        <Label Content="Exp./h:" />
                        <Label x:Name="ExperiencePerHourLabel" Content="-" Margin="80,0,0,0"/>
                    </Grid>
                    <Grid>
                        <Label Content="Level up in:" />
                        <Label x:Name="LevelTimeRemainingLabel" Content="-" Margin="100,0,0,0"/>
                    </Grid>
                    <Grid>
                        <Label Content="Level up at:" />
                        <Label x:Name="LevelUpTimeLabel" Content="-" Margin="100,0,0,0"/>
                    </Grid>
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="ToggleCounterButton" Content="Start counter" Grid.Column="0" Width="Auto" Height="28" Margin="0,0,5,0" Click="ToggleCounterButton_Click"/>
                        <Button x:Name="ResetCounterButton" Content="Reset" Grid.Column="1" Width="Auto" Height="28" Click="ResetCounterButton_Click" IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3Fbfbfbf" Margin="5,0,5,10"/>

            <!-- Timer Section -->
            <StackPanel Margin="5,0,5,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Timer" FontWeight="Bold" Foreground="AntiqueWhite"/>
                    <Button Content="[-]" Grid.Column="1" Width="25" Height="18" Padding="0" FontSize="10" Click="ToggleSection_Click" Tag="TimerContent"/>
                </Grid>
                <StackPanel x:Name="TimerContent">
                    <ProgressBar x:Name="CustomTimerBar" Height="4" Width="238" BorderBrush="Black" Background="{x:Null}" Foreground="#FF00C000" Margin="0,5,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CustomTimerTextBox" Height="28" HorizontalContentAlignment="Center" TextChanged="CustomTimerTextBox_TextChanged" GotKeyboardFocus="CustomTimerTextBox_GotKeyboardFocus" PreviewKeyDown="CustomTimerTextBox_PreviewKeyDown" LostKeyboardFocus="CustomTimerTextBox_LostKeyboardFocus" MaxLength="8" VerticalContentAlignment="Center" />
                        <Button x:Name="CustomTimerButton" Content="Start" Grid.Column="1" Margin="5,0,0,0" Click="CustomTimerButton_Click" Width="67" Height="28" IsEnabled="False"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3Fbfbfbf" Margin="5,0,5,10"/>

            <!-- Exhaustion Section -->
            <StackPanel Margin="5,0,5,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Exhaust Alert" FontWeight="Bold" Foreground="AntiqueWhite"/>
                    <Button Content="[-]" Grid.Column="1" Width="25" Height="18" Padding="0" FontSize="10" Click="ToggleSection_Click" Tag="ExhaustContent"/>
                </Grid>
                <StackPanel x:Name="ExhaustContent">
                    <ProgressBar x:Name="ExhaustionProgressBar" Height="4" Width="238" BorderBrush="Black" Background="{x:Null}" Foreground="Orange" Margin="0,5,0,5"/>
                    <Button x:Name="ToggleExhaustionButton" Content="Enable Exhaust Alert" Width="238" Height="28" Click="ToggleExhaustionButton_Click"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3Fbfbfbf" Margin="5,0,5,10"/>

            <!-- Spell Timer Section -->
            <StackPanel Margin="5,0,5,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Spell Timers" FontWeight="Bold" Foreground="AntiqueWhite"/>
                    <Button Content="[-]" Grid.Column="1" Width="25" Height="18" Padding="0" FontSize="10" Click="ToggleSection_Click" Tag="SpellContent"/>
                </Grid>
                <StackPanel x:Name="SpellContent">
                    <StackPanel x:Name="CooldownsContainer" />
                    <Button x:Name="ToggleSpellTimerButton" Content="Enable Timer Spell" Margin="0,5,0,0" Width="238" Height="28" Click="ToggleSpellTimerButton_Click"/>
                    <Button x:Name="SpellBookButton" Content="OPEN SPELL BOOK" Margin="0,5,0,0" Click="SpellBookButton_Click" Background="#7F3e3e3e" BorderBrush="AntiqueWhite" BorderThickness="1" Foreground="AntiqueWhite" Width="238" Height="28"/>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3Fbfbfbf" Margin="5,0,5,10"/>

            <!-- Search Section -->
            <StackPanel Margin="5,0,5,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Character Search" FontWeight="Bold" Foreground="AntiqueWhite"/>
                    <Button Content="[-]" Grid.Column="1" Width="25" Height="18" Padding="0" FontSize="10" Click="ToggleSection_Click" Tag="SearchContent"/>
                </Grid>
                <StackPanel x:Name="SearchContent">
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="CharacterSearchTextBox" Grid.Column="0" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" PreviewKeyDown="CharacterSearchTextBox_PreviewKeyDown" GotKeyboardFocus="CharacterSearchTextBox_GotKeyboardFocus" TextChanged="CharacterSearchTextBox_TextChanged"/>
                        <Button x:Name="CharacterSearchButton" Grid.Column="1" Content="Search" Width="67" Height="28" Margin="5,0,0,0" Click="CharacterSearchButton_Click"/>
                    </Grid>
                </StackPanel>
            </StackPanel>

            <Separator Background="#3Fbfbfbf" Margin="5,0,5,10"/>

            <!-- Links Section -->
            <StackPanel Margin="5,0,5,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Content="Quick Links" FontWeight="Bold" Foreground="AntiqueWhite"/>
                    <Button Content="[-]" Grid.Column="1" Width="25" Height="18" Padding="0" FontSize="10" Click="ToggleSection_Click" Tag="LinksContent"/>
                </Grid>
                <StackPanel x:Name="LinksContent">
                    <Button x:Name="NetMapViewerButton" Content="Map viewer (opentibia.info)" Margin="0,5,0,5" Width="238" Height="28" Click="NetMapViewerButton_Click"/>
                    <Button x:Name="InfoMapViewerButton" Content="TibiaRelic.com" Margin="0,0,0,5" Width="238" Height="28" Click="InfoMapViewerButton_Click"/>
                    <Button x:Name="TibiaRelicInfoButton" Content="TibiaRelic.wiki" Margin="0,0,0,5" Width="238" Height="28" Click="TibiaRelicInfoButton_Click"/>
                    <Button x:Name="TibiaRelicXyzButton" Content="opentibia.info" Margin="0,0,0,5" Width="238" Height="28" Click="TibiaRelicXyzButton_Click"/>
                </StackPanel>
            </StackPanel>

            <!-- Footer -->
            <Label Content="Do you like my work? Consider donating&#xD;&#xA;to Josuban (Carlin)" FontSize="10" Foreground="#FFA4A4A4" Padding="5,10,5,2" HorizontalContentAlignment="Center"/>
            <Label x:Name="VersionLabel" Content="v2.0" FontSize="10" Foreground="#FFA4A4A4" HorizontalContentAlignment="Center" Padding="5,2,5,10"/>
        </StackPanel>
    </Viewbox>
</Window>
